{
  "name": "dittosloop-for-codex-repo",
  "version": "0.1.7",
  "description": "Git-backed Codex plugin marketplace repo for DittosLoop For Codex.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/502399493zjw-lgtm/dittosloop-for-codex.git"
  },
  "bugs": {
    "url": "https://github.com/502399493zjw-lgtm/dittosloop-for-codex/issues"
  },
  "homepage": "https://github.com/502399493zjw-lgtm/dittosloop-for-codex#readme",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "npm --prefix plugins/dittosloop-for-codex/mcp run build",
    "dev:local": "node scripts/dev-local.mjs",
    "test": "node --test test/*.test.mjs",
    "validate": "node scripts/validate-plugin.mjs",
    "verify:generated": "node scripts/verify-generated.mjs",
    "check": "npm run build && npm run verify:generated && npm run test && npm run validate && npm --prefix plugins/dittosloop-for-codex/mcp test"
  }
}
