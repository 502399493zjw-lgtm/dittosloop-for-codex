{
  "name": "@dittosloop/for-codex-mcp",
  "version": "0.1.6",
  "description": "Local MCP runtime for the DittosLoop For Codex plugin.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/502399493zjw-lgtm/dittosloop-for-codex.git",
    "directory": "plugins/dittosloop-for-codex/mcp"
  },
  "bugs": {
    "url": "https://github.com/502399493zjw-lgtm/dittosloop-for-codex/issues"
  },
  "homepage": "https://github.com/502399493zjw-lgtm/dittosloop-for-codex/tree/main/plugins/dittosloop-for-codex/mcp#readme",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run clean && npm run typecheck && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
